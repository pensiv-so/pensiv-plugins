{
  "name": "pensiv-plugins",
  "version": "0.0.0",
  "private": true,
  "description": "Public monorepo for the Pensiv plugin SDK, authoring kit, and first-party plugins.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "build:sdk": "tsc -b",
    "build": "npm run build:sdk && npm run build --workspaces --if-present",
    "pack-plugin": "node scripts/pack-plugin.mjs",
    "typecheck": "npm run build:sdk && npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.0",
    "react": "^19.2.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.8"
  }
}
